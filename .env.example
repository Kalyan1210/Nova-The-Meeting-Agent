# Google Workspace (run `npm run oauth-setup` after filling client ID/secret)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
AGENT_EMAIL=nova@yourdomain.com

# Google Meet — set false to show browser window during dev, true for headless server runs
MEET_HEADLESS=true

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# OpenAI (Whisper STT + Embeddings)
OPENAI_API_KEY=

# ElevenLabs (TTS)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# Free-tier fallback used automatically when primary voice returns 402
ELEVENLABS_FALLBACK_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Knowledge Base (path to Obsidian vault directory or single .md file)
OBSIDIAN_VAULT_PATH=/path/to/vault

# Web Search (Tavily — https://app.tavily.com)
TAVILY_API_KEY=

# Deepgram — streaming STT with speaker diarization (https://console.deepgram.com)
# When set, replaces Whisper with Deepgram (~200ms latency, speaker labels).
# When empty, falls back to Whisper (batch, no speaker IDs).
DEEPGRAM_API_KEY=

# Authorized emails that can invoke Nova actions (comma-separated).
# Leave empty to allow anyone in the meeting to trigger Nova.
AUTHORIZED_EMAILS=you@yourdomain.com

# OpenClaw (optional)
OPENCLAW_PORT=18789
